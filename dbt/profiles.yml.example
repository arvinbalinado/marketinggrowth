# Copy this file to profiles.yml (NOT committed to git) and fill in your values.
# profiles.yml should live at ~/.dbt/profiles.yml or in this directory.

marketing_growth_analytics:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: "{{ env_var('GCP_PROJECT_ID') }}"
      dataset: dev_staging
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      location: "{{ env_var('GCP_REGION', 'us-central1') }}"
      threads: 4
      timeout_seconds: 300

    staging:
      type: bigquery
      method: service-account
      project: "{{ env_var('GCP_PROJECT_ID') }}"
      dataset: staging
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      location: "{{ env_var('GCP_REGION', 'us-central1') }}"
      threads: 8
      timeout_seconds: 600

    production:
      type: bigquery
      method: service-account
      project: "{{ env_var('GCP_PROJECT_ID') }}"
      dataset: marts
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      location: "{{ env_var('GCP_REGION', 'us-central1') }}"
      threads: 16
      timeout_seconds: 900
